# Copy this file to .env on the self-hosted server.
# Never commit the real .env file.

COMPOSE_PROJECT_NAME=aomlegacy-family-tree
TZ=UTC
HTTP_PORT=8080

# Host paths. These must match the mounted drives from the runbooks.
SSD_DATA_PATH=/srv/aomlegacy
MEDIA_PRIMARY_PATH=/mnt/aom-media-primary
MEDIA_BACKUP_PATH=/mnt/aom-media-backup
CACHE_PATH=/mnt/aom-cache

# Immich database.
IMMICH_DB_USERNAME=immich
IMMICH_DB_PASSWORD=replace-with-a-long-random-password
IMMICH_DB_NAME=immich

# AOM Legacy PostgreSQL.
AOM_DB_USERNAME=aomlegacy
AOM_DB_PASSWORD=replace-with-a-different-long-random-password
AOM_DB_NAME=aomlegacy

# Neo4j format is username/password.
NEO4J_AUTH=neo4j/replace-with-a-long-random-password
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=2g
NEO4J_PAGECACHE=1g

# Future AOM API settings.
AOM_PUBLIC_BASE_URL=http://localhost:8080
AOM_JWT_SECRET=replace-with-at-least-32-random-bytes
AOM_SESSION_SECRET=replace-with-at-least-32-random-bytes
AOM_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Future AI settings. Leave blank for local-only Phase 1 workflows.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Backup behavior.
BACKUP_RETENTION_DAYS=30
BACKUP_LOG_PATH=/srv/aomlegacy/backups/logs
