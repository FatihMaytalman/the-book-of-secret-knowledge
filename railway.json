{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci && npm run build -w @aomlegacy/shared && npm run build -w @aomlegacy/api"
  },
  "deploy": {
    "startCommand": "npm run start:prod -w @aomlegacy/api",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
