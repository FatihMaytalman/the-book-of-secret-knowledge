{
  "name": "@aomlegacy/web",
  "private": true,
  "version": "0.1.0",
  "description": "AOM Legacy Family Tree web app",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000 --hostname 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
