    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "next": "^16.2.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.17",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "tailwindcss": "^4.0.17",
    "typescript": "^6.0.3",
    "wrangler": "^4.24.0"
  }
