NODE_ENV=development
# Local dev: direct API on :3001. Self-hosted nginx proxy uses http://localhost:8080/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
# Production (Cloudflare/Vercel): set to your Railway API URL, e.g. https://bizimkiler-api.up.railway.app/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
