NODE_ENV=development
PORT=3001

# PostgreSQL — Railway injects DATABASE_URL when Postgres is linked.
# For local dev, either set DATABASE_URL or the AOM_DB_* vars below.
DATABASE_URL=postgresql://aomlegacy:replace-me@localhost:5432/aomlegacy
# AOM_DB_HOST=localhost
# AOM_DB_PORT=5432
# AOM_DB_USERNAME=aomlegacy
# AOM_DB_PASSWORD=replace-with-a-different-long-random-password
# AOM_DB_NAME=aomlegacy

# Comma-separated allowed browser origins (supports *.vercel.app wildcards)
# CORS_ORIGINS=https://bizimkiler.aomlegacy.com,https://your-app.vercel.app

# Immich integration (Phase 1 media subsystem)
IMMICH_URL=http://localhost:2283
IMMICH_API_KEY=replace-with-an-immich-api-key

# Claude heritage assistant (Anthropic)
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key

# Memory photo uploads (local filesystem storage for Bizimkiler memories)
BIZIMKILER_UPLOADS_DIR=./uploads
AOM_JWT_SECRET=replace-with-at-least-32-random-bytes

# Optional: create or promote a platform superadmin on startup (first deploy only)
AOM_SUPERADMIN_EMAIL=
AOM_SUPERADMIN_PASSWORD=
# AOM_SUPERADMIN_DISPLAY_NAME=Platform Admin
