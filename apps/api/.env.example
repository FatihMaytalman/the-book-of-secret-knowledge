NODE_ENV=development
PORT=3000

# PostgreSQL (Railway provides DATABASE_URL automatically when linked)
DATABASE_URL=postgresql://aomlegacy:replace-me@localhost:5432/aomlegacy

# Comma-separated allowed browser origins (supports *.vercel.app wildcards)
CORS_ORIGINS=https://bizimkiler.aomlegacy.com,*.vercel.app

# Immich integration (Phase 1 media subsystem)
IMMICH_URL=http://localhost:2283
IMMICH_API_KEY=replace-with-an-immich-api-key

# Claude heritage assistant (Anthropic)
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key

# Memory photo uploads (local filesystem storage for Bizimkiler memories)
BIZIMKILER_UPLOADS_DIR=./uploads
AOM_JWT_SECRET=replace-with-at-least-32-random-bytes
AOM_SESSION_SECRET=replace-with-at-least-32-random-bytes

# Optional: bootstrap a superadmin on first startup (password hash only — never plain text)
# Generate hash with apps/api password util format: scrypt$<salt>$<hash>
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD_HASH=
