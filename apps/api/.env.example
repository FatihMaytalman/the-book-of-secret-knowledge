NODE_ENV=development
PORT=3001

# PostgreSQL — local dev / Docker Compose (AOM_DB_*)
AOM_DB_HOST=localhost
AOM_DB_PORT=5432
AOM_DB_USERNAME=aomlegacy
AOM_DB_PASSWORD=replace-with-a-different-long-random-password
AOM_DB_NAME=aomlegacy

# PostgreSQL — Railway (set automatically when Postgres is linked; overrides AOM_DB_*)
# DATABASE_URL=postgresql://user:pass@host:5432/aomlegacy?sslmode=require

# Comma-separated browser origins (supports *.vercel.app wildcards)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://bizimkiler.aomlegacy.com,*.vercel.app

# Immich integration (Phase 1 media subsystem)
IMMICH_URL=http://localhost:2283
IMMICH_API_KEY=replace-with-an-immich-api-key

# Claude heritage assistant (Anthropic)
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key

# Memory photo uploads (local filesystem storage for Bizimkiler memories)
BIZIMKILER_UPLOADS_DIR=./uploads
AOM_JWT_SECRET=replace-with-at-least-32-random-bytes
AOM_SESSION_SECRET=replace-with-at-least-32-random-bytes

# Optional: bootstrap a superadmin on first startup (password hash only — never plain text)
# Generate hash: node -e "const {scryptSync,randomBytes}=require('crypto');const s=randomBytes(16);const h=scryptSync('your-password',s,64);console.log('scrypt$'+s.toString('hex')+'$'+h.toString('hex'))"
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD_HASH=
